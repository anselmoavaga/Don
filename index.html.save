            { id: 1, nom: "Sophie Durand", role: "Volontaire française, 2023", texte: "Une expérience humaine incomparable. J'ai vu des enfants dont les yeux s'éclairaient en entrant pour la première fois dans leur nouvelle école. Je reviendrai l'an prochain.", photo: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=150" },
            { id: 2, nom: "Marcus Schmidt", role: "Volontaire allemand, 2022", texte: "3APLUS-TOGO m'a appris que le développement durable ne se fait pas pour les communautés, mais avec elles. L'équipe locale est extraordinaire.", photo: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=150" },
            { id: 3, nom: "Ayoko Mensah", role: "Bénéficiaire, mère de 3 enfants", texte: "Avant le forage, nous marchions 2 heures chaque jour pour trouver de l'eau. Aujourd'hui, mes enfants vont à l'école au lieu de porter des jerricans.", photo: "https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=150" }
        ]
    };

    /* ─── STATE ─────────────────────────────── */
    const STATE = {
        projets: [],
        galerie: [],
        membres: [],
        temoignages: [],
        lightboxIndex: 0,
        currentFilter: 'all'
    };

    /* ─── CHARGEMENT DES DONNÉES DEPUIS LES FICHIERS JSON ─── */
  
async function loadJSON(filename) {
    try {
        const response = await fetch(`/_data/${filename}.json`);
        if (!response.ok) throw new Error('Fichier introuvable');
        const data = await response.json();
        // Si c'est un objet avec une clé du même nom que le fichier
        if (data && typeof data === 'object' && !Array.isArray(data)) {
            return data[filename] || [];
        }
        return Array.isArray(data) ? data : [];
    } catch (error) {
        console.warn(`Fallback pour ${filename}`);
        return DEFAULTS[filename] || [];
    }
}

    /* ─── TOAST ─────────────────────────────── */
    function toast(msg, type = 'success') {
        const container = document.getElementById('toast-container');
        const el = document.createElement('div');
        el.className = `toast ${type}`;
        const icon = type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle';
        el.innerHTML = `<i class="fas fa-${icon}"></i> ${msg}`;
        container.appendChild(el);
        setTimeout(() => el.remove(), 3500);
    }

    /* ─── RENDER PROJETS ────────────────────── */
    function renderProjets() {
        const c = document.getElementById('projets-container');
        const filtered = STATE.currentFilter === 'all'
            ? STATE.projets
            : STATE.projets.filter(p => p.cat === STATE.currentFilter);

        if (!filtered.length) {
            c.innerHTML = `<div class="empty-state" style="grid-column:1/-1"><i class="fas fa-folder-open"></i>Aucun projet dans cette catégorie.</div>`;
            return;
        }
        c.innerHTML = filtered.map(p => `
            <div class="projet-card fade-up" data-id="${p.id}">
                <div class="projet-img-wrap">
                    <img src="${p.images?.[0] || 'https://via.placeholder.com/600x300'}" alt="${p.titre}" loading="lazy">
                    <span class="projet-tag">${catLabel(p.cat)}</span>
                </div>
                <div class="projet-body">
                    <div class="projet-date"><i class="fas fa-calendar-alt"></i> ${p.date}</div>
                    <h3>${p.titre}</h3>
                    <p>${p.description.substring(0, 110)}…</p>
                    <div class="projet-footer">
                        <span class="projet-read-more">Lire plus <i class="fas fa-arrow-right"></i></span>
                    </div>
                </div>
            </div>
        `).join('');

        c.querySelectorAll('.projet-card').forEach(card => {
            card.addEventListener('click', () => openProjModal(parseInt(card.dataset.id)));
        });
        observeFadeUps();
    }

    function catLabel(cat) {
        const map = { education:'Éducation', sante:'Santé', environnement:'Environnement', social:'Social' };
        return map[cat] || cat;
    }

    /* ─── RENDER GALERIE ────────────────────── */
    function renderGalerie() {
        const c = document.getElementById('galerie-container');
        STATE.lightboxIndex = 0;
        if (document.getElementById('lightbox').classList.contains('open')) {
            document.getElementById('lightbox').classList.remove('open');
        }

        if (!STATE.galerie.length) {
            c.innerHTML = `<div class="empty-state" style="grid-column:1/-1; color:rgba(255,255,255,0.5)"><i class="fas fa-images"></i>Aucune image.</div>`;
            return;
        }
        c.innerHTML = STATE.galerie.map((img, idx) => `
            <div class="galerie-item" data-idx="${idx}">
                <img src="${img.url}" alt="${img.legende}" loading="lazy">
                <div class="galerie-overlay">
                    <p>${img.legende || ''}</p>
                </div>
            </div>
        `).join('');

        c.querySelectorAll('.galerie-item').forEach(item => {
            item.addEventListener('click', () => openLightbox(parseInt(item.dataset.idx)));
        });
    }

    /* ─── RENDER MEMBRES ────────────────────── */
    function renderMembres() {
        const c = document.getElementById('membres-container');
        if (!STATE.membres.length) {
            c.innerHTML = `<div class="empty-state" style="grid-column:1/-1"><i class="fas fa-users"></i>Aucun membre.</div>`;
            return;
        }
        c.innerHTML = STATE.membres.map(m => `
            <div class="membre-card fade-up">
                <div class="membre-photo-wrap">
                    <img src="${m.photo || 'https://via.placeholder.com/300'}" alt="${m.nom}" loading="lazy">
                </div>
                <div class="membre-body">
                    <h3>${m.nom}</h3>
                    <p class="membre-fonction">${m.fonction}</p>
                    <div class="membre-contacts">
                        ${m.email ? `<a href="mailto:${m.email}" title="Email"><i class="fas fa-envelope"></i></a>` : ''}
                        ${m.tel ? `<a href="tel:${m.tel}" title="Téléphone"><i class="fas fa-phone"></i></a>` : ''}
                    </div>
                </div>
            </div>
        `).join('');
        observeFadeUps();
    }

    /* ─── RENDER TÉMOIGNAGES ────────────────── */
    function renderTemoignages() {
        const c = document.getElementById('temoignages-container');
        if (!STATE.temoignages.length) {
            c.innerHTML = `<div class="empty-state"><i class="fas fa-comment"></i>Aucun témoignage.</div>`;
            return;
        }
        c.innerHTML = STATE.temoignages.map(t => `
            <div class="temoignage-card">
                <div class="temoignage-quote">"</div>
                <p class="temoignage-text">${t.texte}</p>
                <div class="temoignage-author">
                    <img src="${t.photo || 'https://via.placeholder.com/80'}" alt="${t.nom}">
                    <div>
                        <div class="temoignage-name">${t.nom}</div>
                        <div class="temoignage-role">${t.role}</div>
                    </div>
                </div>
            </div>
        `).join('');
    }

    /* ─── MODAL PROJET ──────────────────────── */
    function openProjModal(id) {
        const p = STATE.projets.find(x => x.id === id);
        if (!p) return;
        document.getElementById('modal-tag').textContent = catLabel(p.cat);
        document.getElementById('modal-title').textContent = p.titre;
        document.getElementById('modal-date').innerHTML = `<i class="fas fa-calendar-alt"></i> ${p.date}`;
        document.getElementById('modal-desc').textContent = p.description;
        const imgC = document.getElementById('modal-images');
        imgC.innerHTML = (p.images||[]).map(src => `<img src="${src}" alt="${p.titre}">`).join('');
        document.getElementById('proj-modal').classList.add('open');
    }

    /* ─── LIGHTBOX ──────────────────────────── */
    function openLightbox(idx) {
        if (!STATE.galerie.length || idx < 0 || idx >= STATE.galerie.length) return;
        STATE.lightboxIndex = idx;
        updateLightbox();
        document.getElementById('lightbox').classList.add('open');
    }
    function updateLightbox() {
        const img = STATE.galerie[STATE.lightboxIndex];
        if (img) document.getElementById('lightbox-img').src = img.url;
    }

    /* ─── RENDER ALL ────────────────────────── */
    function renderAll() {
        renderProjets();
        renderGalerie();
        renderMembres();
        renderTemoignages();
    }

    /* ─── FILTRES ────────────────────────────── */
    document.getElementById('proj-filters').addEventListener('click', e => {
        const btn = e.target.closest('.filter-btn');
        if (!btn) return;
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        STATE.currentFilter = btn.dataset.cat;
        renderProjets();
    });

    /* ─── THEME TOGGLE ──────────────────────── */
    document.getElementById('theme-toggle').addEventListener('click', () => {
        const html = document.documentElement;
        const isDark = html.getAttribute('data-theme') === 'dark';
        html.setAttribute('data-theme', isDark ? 'light' : 'dark');
        document.getElementById('theme-icon').className = isDark ? 'fas fa-moon' : 'fas fa-sun';
        localStorage.setItem('3a_theme', isDark ? 'light' : 'dark');
    });
    (function applyTheme() {
        const t = localStorage.getItem('3a_theme');
        if (t === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
            document.getElementById('theme-icon').className = 'fas fa-sun';
        }
    })();

    /* ─── MOBILE MENU ───────────────────────── */
    document.getElementById('menu-toggle').addEventListener('click', () => {
        document.getElementById('nav-links').classList.toggle('open');
    });
    document.querySelectorAll('.nav-links a').forEach(a => {
        a.addEventListener('click', () => document.getElementById('nav-links').classList.remove('open'));
    });

    /* ─── MODAL CLOSE ───────────────────────── */
    document.querySelectorAll('[data-close]').forEach(btn => {
        btn.addEventListener('click', () => {
            document.getElementById(btn.dataset.close).classList.remove('open');
        });
    });
    document.querySelectorAll('.modal-backdrop').forEach(modal => {
        modal.addEventListener('click', e => {
            if (e.target === modal) modal.classList.remove('open');
        });
    });

    /* ─── LIGHTBOX NAVIGATION ────────────────── */
    document.getElementById('lightbox-close').addEventListener('click', () => {
        document.getElementById('lightbox').classList.remove('open');
    });
    document.getElementById('lightbox-prev').addEventListener('click', () => {
        STATE.lightboxIndex = (STATE.lightboxIndex - 1 + STATE.galerie.length) % STATE.galerie.length;
        updateLightbox();
    });
    document.getElementById('lightbox-next').addEventListener('click', () => {
        STATE.lightboxIndex = (STATE.lightboxIndex + 1) % STATE.galerie.length;
        updateLightbox();
    });
    document.addEventListener('keydown', e => {
        if (document.getElementById('lightbox').classList.contains('open')) {
            if (e.key === 'ArrowLeft') document.getElementById('lightbox-prev').click();
            if (e.key === 'ArrowRight') document.getElementById('lightbox-next').click();
            if (e.key === 'Escape') document.getElementById('lightbox').classList.remove('open');
        }
        if (document.getElementById('proj-modal').classList.contains('open') && e.key === 'Escape') {
            document.getElementById('proj-modal').classList.remove('open');
        }
    });

    /* ─── SCROLL BEHAVIORS ──────────────────── */
    const header = document.getElementById('site-header');
    const backTop = document.getElementById('back-to-top');
    window.addEventListener('scroll', () => {
        header.classList.toggle('scrolled', scrollY > 40);
        backTop.classList.toggle('visible', scrollY > 400);
    }, { passive: true });
    backTop.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

    /* ─── ACTIVE NAV ────────────────────────── */
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-links a');
    const io = new IntersectionObserver(entries => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                navLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + entry.target.id));
            }
        });
    }, { rootMargin: '-50% 0px -50% 0px' });
    sections.forEach(s => io.observe(s));

    /* ─── COUNTERS ──────────────────────────── */
    const counterEls = document.querySelectorAll('[data-target]');
    const counterMap = new Map();
    counterEls.forEach(el => counterMap.set(el, parseInt(el.dataset.target)));

    const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            const el = entry.target;
            if (entry.isIntersecting) {
                el.textContent = '0';
                const target = counterMap.get(el);
                let start = 0;
                const step = target / 60;
                const timer = setInterval(() => {
                    start += step;
                    if (start >= target) { el.textContent = target; clearInterval(timer); return; }
                    el.textContent = Math.ceil(start);
                }, 16);
            } else {
                el.textContent = '0';
            }
        });
    }, { threshold: 0.5 });
    counterEls.forEach(el => counterObserver.observe(el));

    /* ─── FADE UP ON SCROLL ─────────────────── */
    function observeFadeUps() {
        const fadeObs = new IntersectionObserver(entries => {
            entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); fadeObs.unobserve(e.target); } });
        }, { threshold: 0.1 });
        document.querySelectorAll('.fade-up:not(.visible)').forEach(el => fadeObs.observe(el));
    }

    /* ─── DON PROGRESS ──────────────────────── */
    document.querySelectorAll('.don-amount-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.don-amount-btn').forEach(b => b.classList.remove('selected'));
            btn.classList.add('selected');
        });
    });
    (function animateDonBar() {
        const bar = document.getElementById('don-bar');
        const barObs = new IntersectionObserver(entries => {
            if (entries[0].isIntersecting) { bar.style.width = '65%'; barObs.disconnect(); }
        }, { threshold: 0.5 });
        barObs.observe(bar);
    })();

    /* ─── NEWSLETTER ────────────────────────── */
    document.getElementById('nl-submit').addEventListener('click', () => {
        const email = document.getElementById('nl-email').value.trim();
        if (!email || !email.includes('@')) { toast('Veuillez entrer un email valide', 'error'); return; }
        toast('Merci ! Vous êtes inscrit à la newsletter.', 'success');
        document.getElementById('nl-email').value = '';
    });

    /* ─── CONTACT FORM ──────────────────────── */
    document.getElementById('contact-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const form = e.target;
        const formData = new FormData(form);
        try {
            const response = await fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: { 'Accept': 'application/json' }
            });
            if (response.ok) {
                toast('Message envoyé avec succès ! Nous vous répondrons sous 48h.', 'success');
                form.reset();
            } else {
                toast('Erreur lors de l\'envoi. Veuillez réessayer.', 'error');
            }
        } catch (error) {
            toast('Problème réseau. Vérifiez votre connexion.', 'error');
        }
    });

    /* ─── GESTION DU BOUTON RETOUR ───────────── */
    (function handleBackButton() {
        history.pushState({ page: 'home' }, '', '#');
        window.addEventListener('popstate', () => {
            if (window.scrollY > 10) {
                window.scrollTo({ top: 0, behavior: 'smooth' });
                history.pushState({ page: 'home' }, '', '#');
            }
        });
    })();

    /* ─── INIT ──────────────────────────────── */
    (async function init() {
        await fetchAllData();
        renderAll();
        observeFadeUps();
    })();
</script>
</body>
</html>
