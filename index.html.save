<!DOCTYPE html>
<html lang="fr" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>3APLUS-TOGO | Solidarité, Action, Avenir</title>
    <meta name="description" content="Association humanitaire togolaise active depuis 2015 à Tsévie — éducation, santé, environnement.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* ═══════════════════════════════════════════
           TOKENS
        ═══════════════════════════════════════════ */
        :root {
            --blue-night: #0B1F4B;
            --blue-mid: #1A3A6B;
            --gold: #E8A020;
            --gold-light: #FBE8C0;
            --green-togo: #2D6A4F;
            --cream: #F7F5F0;
            --white: #FFFFFF;
            --gray-soft: #EDF2F7;
            --gray-mid: #94A3B8;
            --text-dark: #0B1F4B;
            --text-body: #334155;
            --shadow-card: 0 8px 32px rgba(11,31,75,0.10);
            --shadow-hover: 0 20px 48px rgba(11,31,75,0.18);
            --radius: 20px;
            --radius-sm: 12px;
            --transition: 0.28s cubic-bezier(0.4,0,0.2,1);
            --font-display: 'Playfair Display', Georgia, serif;
            --font-body: 'DM Sans', system-ui, sans-serif;
            --container-max: 1400px;
        }
        [data-theme="dark"] {
            --cream: #0F172A;
            --white: #1E293B;
            --gray-soft: #1E293B;
            --text-dark: #F1F5F9;
            --text-body: #CBD5E1;
            --shadow-card: 0 8px 32px rgba(0,0,0,0.4);
        }

        *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior: smooth; }
        body            font-family: var(--font-body);
            background: var(--cream);
            color: var(--text-body);
            line-height: 1.65;
            transition: background var(--transition), color var(--transition);
        }
        img { display:block; max-width:100%; }
        a { color: inherit; text-decoration: none; }
        button { font-family: var(--font-body); cursor: pointer; border: none; }

        .container { max-width: var(--container-max); margin: 0 auto; padding: 0 32px; }
        .section-pad { padding: 96px 0; }
        .section-pad-sm { padding: 64px 0; }

        .display { font-family: var(--font-display); }
        .eyebrow {
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 12px;
        }
        h1, h2, h3 { font-family: var(--font-display); color: var(--text-dark); line-height: 1.2; }
        h1 { font-size: clamp(2.4rem, 5vw, 4.2rem); }
        h2 { font-size: clamp(1.8rem, 3.5vw, 2.8rem); }
        h3 { font-size: 1.25rem; }

        .btn {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 14px 28px; border-radius: 50px;
            font-weight: 600; font-size: 0.95rem;
            transition: var(--transition); cursor: pointer;
        }
        .btn-gold { background: var(--gold); color: var(--blue-night); box-shadow: 0 4px 20px rgba(232,160,32,0.35); }
        .btn-gold:hover { background: #d4901a; transform: translateY(-2px); box-shadow: 0 8px 28px rgba(232,160,32,0.45); }
        .btn-outline { background: transparent; border: 2px solid var(--white); color: var(--white); }
        .btn-outline:hover { background: var(--white); color: var(--blue-night); }
        .btn-ghost { background: transparent; border: 2px solid var(--blue-night); color: var(--blue-night); }
        .btn-ghost:hover { background: var(--blue-night); color: var(--white); }
        .btn-sm { padding: 8px 18px; font-size: 0.85rem; }

        #site-header {
            position: sticky; top: 0; z-index: 900;
            background: rgba(11,31,75,0.97);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            transition: box-shadow var(--transition);
        }
        #site-header.scrolled { box-shadow: 0 4px 24px rgba(0,0,0,0.25); }
        .nav-inner {
            display: flex; align-items: center; justify-content: space-between;
            padding: 18px 0; gap: 24px;
        }
        .logo {
            font-family: var(--font-display);
            font-size: 1.6rem; font-weight: 900;
            color: var(--white);
        }
        .logo span { color: var(--gold); }
        .nav-links {
            display: flex; align-items: center; gap: 32px;
            list-style: none;
        }
        .nav-links a {
            color: rgba(255,255,255,0.75);
            font-size: 0.9rem; font-weight: 500;
            transition: color var(--transition); position: relative;
        }
        .nav-links a::after {
            content: ''; position: absolute; bottom: -4px; left: 0;
            width: 0; height: 2px; background: var(--gold);
            transition: width var(--transition);
        }
        .nav-links a:hover, .nav-links a.active { color: var(--white); }
        .nav-links a:hover::after { width: 100%; }
        .nav-actions { display: flex; align-items: center; gap: 12px; }
        .theme-toggle {
            background: rgba(255,255,255,0.1); border: none;
            width: 38px; height: 38px; border-radius: 50%;
            color: white; font-size: 1rem; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: background var(--transition);
        }
        .theme-toggle:hover { background: rgba(255,255,255,0.2); }
        .menu-toggle {
            display: none; background: none; border: none;
            color: white; font-size: 1.6rem; cursor: pointer;
        }

        #hero {
            position: relative;
            background: var(--blue-night);
            min-height: 100vh;
            display: flex; flex-direction: column; justify-content: center;
            overflow: hidden;
        }
        .hero-bg {
            position: absolute; inset: 0;
            background-image: url('https://images.unsplash.com/photo-1532629345422-7515f3d16bb6?w=1400&q=80');
            background-size: cover; background-position: center;
            opacity: 0.18;
        }
        .hero-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(160deg, rgba(11,31,75,0.9) 40%, rgba(45,106,79,0.5) 100%);
        }
        .hero-content {
            position: relative; z-index: 2;
            padding: 100px 0 80px;
        }
        .hero-impact-number {
            font-family: var(--font-display);
            font-size: clamp(7rem, 20vw, 18rem);
            font-weight: 900;
            color: transparent;
            -webkit-text-stroke: 2px rgba(232,160,32,0.3);
            line-height: 0.85;
            position: absolute; right: -2%; top: 50%;
            transform: translateY(-50%);
            pointer-events: none; user-select: none;
            z-index: 1;
        }
        .hero-inner { position: relative; z-index: 2; max-width: 700px; }
        .hero-eyebrow { color: var(--gold); font-weight: 600; letter-spacing: 0.1em; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 20px; }
        .hero-title { color: var(--white); margin-bottom: 24px; }
        .hero-title em { color: var(--gold); font-style: italic; }
        .hero-subtitle { color: rgba(255,255,255,0.72); font-size: 1.1rem; max-width: 520px; margin-bottom: 40px; }
        .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; }
        .hero-stats {
            position: relative; z-index: 2;
            display: flex; flex-wrap: wrap; gap: 0;
            border-top: 1px solid rgba(255,255,255,0.1);
            margin-top: 64px; padding-top: 40px;
        }
        .hero-stat {
            flex: 1; min-width: 140px;
            padding: 0 32px 0 0;
            border-right: 1px solid rgba(255,255,255,0.1);
        }
        .hero-stat:last-child { border-right: none; }
        .hero-stat-num {
            font-family: var(--font-display);
            font-size: 2.6rem; font-weight: 700;
            color: var(--gold);
        }
        .hero-stat-label { color: rgba(255,255,255,0.6); font-size: 0.85rem; margin-top: 4px; }

        .scroll-hint {
            position: absolute; bottom: 32px; left: 50%;
            transform: translateX(-50%); z-index: 3;
            display: flex; flex-direction: column; align-items: center; gap: 8px;
            color: rgba(255,255,255,0.4); font-size: 0.75rem;
            animation: bob 2s ease-in-out infinite;
        }
        @keyframes bob { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(6px)} }

        #missions { background: var(--white); }
        .missions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 24px; margin-top: 48px;
        }
        .mission-card {
            background: var(--cream);
            border-radius: var(--radius);
            padding: 36px 28px;
            border: 1px solid transparent;
            transition: var(--transition);
        }
        .mission-card:hover {
            border-color: var(--gold);
            transform: translateY(-6px);
            box-shadow: var(--shadow-hover);
        }
        .mission-icon {
            width: 56px; height: 56px; border-radius: var(--radius-sm);
            background: var(--gold-light);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem; color: var(--gold);
            margin-bottom: 20px;
        }
        .mission-card h3 { margin-bottom: 10px; color: var(--text-dark); }
        .mission-card p { font-size: 0.92rem; color: var(--text-body); }

        #projets { background: var(--cream); }
        .filters {
            display: flex; flex-wrap: wrap; gap: 10px;
            margin: 32px 0 40px;
        }
        .filter-btn {
            padding: 8px 20px; border-radius: 50px;
            background: var(--gray-soft);
            color: var(--text-body);
            border: 2px solid transparent;
            font-size: 0.88rem; font-weight: 500;
            transition: var(--transition); cursor: pointer;
        }
        .filter-btn.active {
            background: var(--blue-night); color: white;
            border-color: var(--blue-night);
        }
        .projets-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
            gap: 32px;
        }
        .projet-card {
            background: var(--white);
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: var(--shadow-card);
            transition: var(--transition);
            cursor: pointer;
        }
        .projet-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-hover); }
        .projet-img-wrap { position: relative; overflow: hidden; height: 240px; }
        .projet-img-wrap img { width:100%; height:100%; object-fit:cover; transition: transform 0.5s ease; }
        .projet-card:hover .projet-img-wrap img { transform: scale(1.06); }
        .projet-tag {
            position: absolute; top: 14px; left: 14px;
            background: var(--blue-night); color: white;
            padding: 4px 12px; border-radius: 50px;
            font-size: 0.75rem; font-weight: 600;
        }
        .projet-body { padding: 22px 24px; }
        .projet-date { color: var(--gold); font-size: 0.8rem; font-weight: 600; margin-bottom: 8px; }
        .projet-body h3 { margin-bottom: 10px; font-size: 1.1rem; }
        .projet-body p { font-size: 0.88rem; color: var(--text-body); margin-bottom: 16px; }
        .projet-footer {
            display: flex; justify-content: space-between; align-items: center;
            padding-top: 16px; border-top: 1px solid var(--gray-soft);
        }
        .projet-read-more { color: var(--gold); font-size: 0.85rem; font-weight: 600; display: flex; align-items: center; gap: 4px; }

        #galerie { background: var(--blue-night); }
        #galerie h2, #galerie .eyebrow { color: var(--white); }
        .galerie-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 20px; margin-top: 40px;
        }
        .galerie-item {
            position: relative; border-radius: var(--radius-sm);
            overflow: hidden; cursor: zoom-in;
            aspect-ratio: 4/3;
        }
        .galerie-item img { width:100%; height:100%; object-fit:cover; transition: transform 0.5s ease; }
        .galerie-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(to top, rgba(11,31,75,0.85) 0%, transparent 60%);
            opacity: 0; transition: var(--transition);
            display: flex; align-items: flex-end; padding: 16px;
        }
        .galerie-overlay p { color: white; font-size: 0.85rem; font-weight: 500; }
        .galerie-item:hover img { transform: scale(1.08); }
        .galerie-item:hover .galerie-overlay { opacity: 1; }

        #temoignages { background: var(--white); }
        .temoignages-track {
            display: flex; gap: 24px;
            overflow-x: auto;
            padding-bottom: 16px;
            scroll-snap-type: x mandatory;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }
        .temoignages-track::-webkit-scrollbar { display: none; }
        .temoignage-card {
            flex: 0 0 340px; scroll-snap-align: start;
            background: var(--cream);
            border-radius: var(--radius);
            padding: 32px;
            border-left: 4px solid var(--gold);
        }
        .temoignage-quote { font-size: 2.5rem; color: var(--gold); font-family: var(--font-display); line-height: 1; margin-bottom: 12px; }
        .temoignage-text { font-size: 0.92rem; color: var(--text-body); margin-bottom: 20px; font-style: italic; }
        .temoignage-author { display: flex; align-items: center; gap: 12px; }
        .temoignage-author img { width: 42px; height: 42px; border-radius: 50%; object-fit: cover; }
        .temoignage-name { font-weight: 600; font-size: 0.9rem; color: var(--text-dark); }
        .temoignage-role { font-size: 0.78rem; color: var(--gray-mid); }

        #membres { background: var(--cream); }
        .membres-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px; margin-top: 40px;
        }
        .membre-card {
            background: var(--white);
            border-radius: var(--radius);
            overflow: hidden;
            box-shadow: var(--shadow-card);
            transition: var(--transition);
            text-align: center;
        }
        .membre-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-hover); }
        .membre-photo-wrap { position: relative; height: 200px; overflow: hidden; }
        .membre-photo-wrap img { width:100%; height:100%; object-fit:cover; }
        .membre-body { padding: 20px; }
        .membre-body h3 { margin-bottom: 4px; font-size: 1rem; }
        .membre-fonction { color: var(--gold); font-size: 0.82rem; font-weight: 600; margin-bottom: 10px; }
        .membre-contacts { display: flex; justify-content: center; gap: 10px; }
        .membre-contacts a {
            width: 34px; height: 34px; border-radius: 50%;
            background: var(--gray-soft);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.85rem; color: var(--text-body);
            transition: var(--transition);
        }
        .membre-contacts a:hover { background: var(--gold); color: white; }

        #don {
            background: linear-gradient(135deg, var(--blue-night) 0%, var(--blue-mid) 50%, var(--green-togo) 100%);
            padding: 96px 0; text-align: center; position: relative; overflow: hidden;
        }
        #don::before {
            content: '♥'; position: absolute;
            font-size: 40rem; opacity: 0.03;
            font-family: var(--font-display);
            top: 50%; left: 50%; transform: translate(-50%,-50%);
            pointer-events: none;
        }
        #don h2 { color: var(--white); margin-bottom: 16px; }
        #don p { color: rgba(255,255,255,0.72); max-width: 520px; margin: 0 auto 40px; }
        .don-amounts {
            display: flex; flex-wrap: wrap; justify-content: center;
            gap: 12px; margin-bottom: 32px;
        }
        .don-amount-btn {
            padding: 10px 24px; border-radius: 50px;
            background: rgba(255,255,255,0.12);
            color: white; font-weight: 600; border: 2px solid rgba(255,255,255,0.25);
            font-size: 0.95rem; cursor: pointer;
            transition: var(--transition);
        }
        .don-amount-btn:hover, .don-amount-btn.selected {
            background: var(--gold); border-color: var(--gold); color: var(--blue-night);
        }
        .don-progress-wrap { max-width: 500px; margin: 0 auto 32px; }
        .don-progress-label { display: flex; justify-content: space-between; color: rgba(255,255,255,0.6); font-size: 0.85rem; margin-bottom: 10px; }
        .don-progress-bar { height: 10px; background: rgba(255,255,255,0.15); border-radius: 50px; overflow: hidden; }
        .don-progress-fill { height: 100%; background: var(--gold); border-radius: 50px; transition: width 1.5s ease; }

        #newsletter { background: var(--gold-light); padding: 64px 0; }
        .newsletter-inner {
            display: flex; flex-wrap: wrap; gap: 32px;
            align-items: center; justify-content: space-between;
        }
        .newsletter-text h2 { font-size: 1.9rem; }
        .newsletter-text p { color: var(--text-body); margin-top: 8px; }
        .newsletter-form { display: flex; gap: 12px; flex-wrap: wrap; }
        .newsletter-form input {
            padding: 14px 20px; border-radius: 50px; border: 2px solid transparent;
            background: white; font-size: 0.95rem; width: 280px;
            font-family: var(--font-body); outline: none;
            transition: border-color var(--transition);
        }
        .newsletter-form input:focus { border-color: var(--gold); }

        #contact { background: var(--white); }
        .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-top: 48px; }
        .contact-info h3 { margin-bottom: 24px; }
        .contact-line {
            display: flex; gap: 16px; align-items: flex-start;
            margin-bottom: 20px; font-size: 0.95rem;
        }
        .contact-line-icon {
            width: 40px; height: 40px; border-radius: var(--radius-sm);
            background: var(--gold-light); color: var(--gold);
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0; font-size: 1rem;
        }
        .contact-form input, .contact-form textarea, .contact-form select {
            width: 100%; padding: 14px 18px;
            border-radius: var(--radius-sm); border: 2px solid var(--gray-soft);
            background: var(--cream); font-family: var(--font-body);
            font-size: 0.95rem; color: var(--text-dark); margin-bottom: 14px;
            outline: none; transition: border-color var(--transition);
        }
        .contact-form input:focus, .contact-form textarea:focus { border-color: var(--gold); }
        .contact-form textarea { resize: vertical; min-height: 120px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
        .map-wrap { margin-top: 32px; border-radius: var(--radius); overflow: hidden; }

        footer {
            background: #060F25; color: rgba(255,255,255,0.55);
            padding: 64px 0 32px;
        }
        .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
        .footer-logo { font-family: var(--font-display); font-size: 1.6rem; font-weight: 900; color: white; margin-bottom: 16px; }
        .footer-logo span { color: var(--gold); }
        .footer-desc { font-size: 0.88rem; line-height: 1.7; max-width: 280px; }
        .footer-col h4 { color: white; font-size: 0.9rem; font-weight: 600; margin-bottom: 20px; letter-spacing: 0.05em; }
        .footer-links { list-style: none; display: flex; flex-direction: column; gap: 10px; }
        .footer-links a { font-size: 0.88rem; transition: color var(--transition); }
        .footer-links a:hover { color: var(--gold); }
        .social-links { display: flex; gap: 10px; margin-top: 20px; }
        .social-link {
            width: 38px; height: 38px; border-radius: 50%;
            background: rgba(255,255,255,0.08);
            display: flex; align-items: center; justify-content: center;
            color: rgba(255,255,255,0.7); transition: var(--transition);
        }
        .social-link:hover { background: var(--gold); color: var(--blue-night); }
        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.06);
            padding-top: 24px; display: flex; justify-content: space-between;
            align-items: center; flex-wrap: wrap; gap: 12px;
            font-size: 0.83rem;
        }
        .footer-bottom a { transition: color var(--transition); }
        .footer-bottom a:hover { color: var(--gold); }

        .whatsapp-fab {
            position: fixed; bottom: 28px; right: 28px;
            width: 58px; height: 58px; border-radius: 50%;
            background: #25D366; color: white;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.7rem; z-index: 800;
            box-shadow: 0 4px 20px rgba(37,211,102,0.4);
            transition: var(--transition);
        }
        .whatsapp-fab:hover { transform: scale(1.1); box-shadow: 0 8px 28px rgba(37,211,102,0.5); }
        .back-to-top {
            position: fixed; bottom: 100px; right: 28px;
            width: 48px; height: 48px; border-radius: 50%;
            background: rgba(11,31,75,0.8); color: white;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; z-index: 800; cursor: pointer;
            opacity: 0; pointer-events: none;
            transition: var(--transition);
        }
        .back-to-top.visible { opacity: 1; pointer-events: all; }
        .back-to-top:hover { background: var(--blue-night); }

        .modal-backdrop {
            display: none; position: fixed; inset: 0;
            background: rgba(6,15,37,0.85);
            backdrop-filter: blur(4px);
            z-index: 1000; align-items: center; justify-content: center;
            padding: 24px;
        }
        .modal-backdrop.open { display: flex; }
        .modal-box {
            background: var(--white); border-radius: 28px;
            width: 100%; max-width: 720px;
            max-height: 90vh; overflow-y: auto;
            position: relative; padding: 36px;
        }
        .modal-close-btn {
            position: sticky; top: 0; float: right;
            background: var(--gray-soft); border: none;
            width: 38px; height: 38px; border-radius: 50%;
            font-size: 1.1rem; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            color: var(--text-dark); transition: var(--transition);
        }
        .modal-close-btn:hover { background: var(--blue-night); color: white; }
        .modal-proj-images { display: flex; gap: 12px; overflow-x: auto; margin: 20px 0; padding-bottom: 8px; }
        .modal-proj-images img { height: 200px; border-radius: var(--radius-sm); flex-shrink: 0; }

        #lightbox { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.95); z-index: 1100; align-items: center; justify-content: center; }
        #lightbox.open { display: flex; }
        #lightbox img { max-width: 90vw; max-height: 90vh; border-radius: var(--radius-sm); }
        #lightbox-close { position: absolute; top: 20px; right: 24px; color: white; font-size: 2rem; cursor: pointer; }
        #lightbox-prev, #lightbox-next {
            position: absolute; top: 50%; transform: translateY(-50%);
            background: rgba(255,255,255,0.1); color: white;
            border: none; width: 50px; height: 50px; border-radius: 50%;
            font-size: 1.2rem; cursor: pointer; display: flex; align-items: center; justify-content: center;
            transition: background var(--transition);
        }
        #lightbox-prev:hover, #lightbox-next:hover { background: var(--gold); color: var(--blue-night); }
        #lightbox-prev { left: 20px; }
        #lightbox-next { right: 20px; }

        #toast-container { position: fixed; top: 80px; right: 24px; z-index: 2000; display: flex; flex-direction: column; gap: 10px; }
        .toast {
            background: var(--blue-night); color: white;
            padding: 14px 20px; border-radius: var(--radius-sm);
            font-size: 0.9rem; box-shadow: var(--shadow-card);
            display: flex; align-items: center; gap: 10px;
            animation: slideIn 0.3s ease;
            min-width: 240px;
        }
        .toast.success { border-left: 4px solid #22C55E; }
        .toast.error { border-left: 4px solid #EF4444; }
        .toast.info { border-left: 4px solid var(--gold); }
        @keyframes slideIn { from{transform:translateX(100%);opacity:0} to{transform:translateX(0);opacity:1} }

        .text-center { text-align: center; }
        .mt-8 { margin-top: 8px; }
        .mt-16 { margin-top: 16px; }
        .mt-32 { margin-top: 32px; }
        .mb-16 { margin-bottom: 16px; }
        .empty-state {
            text-align: center; padding: 64px 24px;
            color: var(--gray-mid); font-size: 0.95rem;
        }
        .empty-state i { font-size: 2.5rem; margin-bottom: 12px; display: block; }
        .fade-up { opacity: 0; transform: translateY(30px); transition: opacity 0.6s ease, transform 0.6s ease; }
        .fade-up.visible { opacity: 1; transform: translateY(0); }

        @media (max-width: 900px) {
            .footer-grid { grid-template-columns: 1fr 1fr; }
            .contact-grid { grid-template-columns: 1fr; }
        }
        @media (max-width: 768px) {
            .nav-links { display: none; position: absolute; top: 100%; left: 0; right: 0; background: var(--blue-night); flex-direction: column; align-items: center; gap: 24px; padding: 32px; border-top: 1px solid rgba(255,255,255,0.1); }
            .nav-links.open { display: flex; }
            .menu-toggle { display: block; }
            .hero-impact-number { font-size: 30vw; opacity: 0.08; }
            .hero-stats { gap: 20px; }
            .hero-stat { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); padding: 0 0 20px; }
            .footer-grid { grid-template-columns: 1fr; gap: 32px; }
            .form-row { grid-template-columns: 1fr; }
            .newsletter-inner { flex-direction: column; }
            .newsletter-form input { width: 100%; }
            .contact-grid { grid-template-columns: 1fr; }
            .projets-grid { grid-template-columns: 1fr; }
            .galerie-grid { grid-template-columns: 1fr 1fr; }
        }
        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
        }
    </style>
</head>
<body>

<!-- ══════════════════ HEADER ══════════════════ -->
<header id="site-header">
    <div class="container">
        <nav class="nav-inner">
