                <button class="menu-toggle" id="menu-toggle" aria-label="Menu">
                    <i class="fas fa-bars"></i>
                </button>
            </div>
        </nav>
    </div>
</header>

<!-- ══════════════════ HERO ══════════════════ -->
<section id="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-impact-number" id="hero-big-num">+620</div>
    <div class="container">
        <div class="hero-content">
            <div class="hero-inner">
                <p class="hero-eyebrow">✦ Association humanitaire · Tsévie, Togo · Depuis 2015</p>
                <h1 class="hero-title">
                    Agir pour <em>l'éducation</em>,<br>la santé et l'environnement
                </h1>
                <p class="hero-subtitle">Nous mobilisons des volontaires internationaux pour transformer des vies dans les communautés togolaises.</p>
                <div class="hero-cta">
                    <a href="#don" class="btn btn-gold"><i class="fas fa-heart"></i> Soutenir la cause</a>
                    <a href="#projets" class="btn btn-outline"><i class="fas fa-arrow-right"></i> Voir nos projets</a>
                </div>
            </div>
            <div class="hero-stats" id="hero-stats">
                <div class="hero-stat">
                    <div class="hero-stat-num" data-target="15">0</div>
                    <div class="hero-stat-label">Projets réalisés</div>
                </div>
                <div class="hero-stat">
                    <div class="hero-stat-num" data-target="620">0</div>
                    <div class="hero-stat-label">Enfants aidés</div>
                </div>
                <div class="hero-stat">
                    <div class="hero-stat-num" data-target="245">0</div>
                    <div class="hero-stat-label">Volontaires</div>
                </div>
                <div class="hero-stat">
                    <div class="hero-stat-num" data-target="7">0</div>
                    <div class="hero-stat-label">Forages construits</div>
                </div>
            </div>
        </div>
    </div>
    <div class="scroll-hint">
        <i class="fas fa-chevron-down"></i>
        <span>Découvrir</span>
    </div>
</section>

<!-- ══════════════════ MISSIONS ══════════════════ -->
<section id="missions" class="section-pad">
    <div class="container">
        <p class="eyebrow text-center fade-up">Ce que nous faisons</p>
        <h2 class="text-center fade-up">Nos domaines d'action</h2>
        <div class="missions-grid mt-32">
            <div class="mission-card fade-up">
                <div class="mission-icon"><i class="fas fa-book-open"></i></div>
                <h3>Éducation</h3>
                <p>Construction d'écoles, bibliothèques, soutien scolaire et alphabétisation pour les enfants des zones rurales.</p>
            </div>
            <div class="mission-card fade-up">
                <div class="mission-icon"><i class="fas fa-heartbeat"></i></div>
                <h3>Santé</h3>
                <p>Lutte contre le paludisme, construction de cases de santé, sensibilisation au VIH et accès à l'eau potable.</p>
            </div>
            <div class="mission-card fade-up">
                <div class="mission-icon"><i class="fas fa-tree"></i></div>
                <h3>Environnement</h3>
                <p>Reboisement, éducation écologique, jardins communautaires et sensibilisation aux enjeux climatiques locaux.</p>
            </div>
            <div class="mission-card fade-up">
                <div class="mission-icon"><i class="fas fa-hands-helping"></i></div>
                <h3>Aide sociale</h3>
                <p>Soutien aux orphelins, parrainage scolaire, aide aux familles vulnérables et insertion professionnelle des jeunes.</p>
            </div>
        </div>
    </div>
</section>

